{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "build": {
    "devPath": "http://localhost:5173",
    "distDir": "../dist",
    "frontendDist": "../dist"
  },
  "productName": "MarkEdit",
  "version": "1.0.0",
  "identifier": "com.markedit.app",
  "app": {
    "windows": [
      {
        "title": "MarkEdit",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "copyright": "",
    "category": "DeveloperTool",
    "shortDescription": "轻量级Markdown编辑器",
    "longDescription": "一个简洁高效的Markdown编辑器，支持实时预览和多种导出格式。"
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}