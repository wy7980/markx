{
  "productName": "MarkEdit",
  "version": "1.0.1",
  "identifier": "com.markedit.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "MarkEdit",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "label": "main",
        "visible": false,
        "devtools": true
      },
      {
        "label": "splashscreen",
        "url": "splashscreen.html",
        "width": 420,
        "height": 320,
        "decorations": false,
        "center": true,
        "resizable": false,
        "alwaysOnTop": true,
        "transparent": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "name": "Markdown Document",
        "description": "MarkEdit Markdown Document",
        "role": "Editor",
        "mimeType": "text/markdown"
      },
      {
        "ext": ["txt"],
        "name": "Text Document",
        "description": "Plain Text Document",
        "role": "Editor",
        "mimeType": "text/plain"
      }
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "fs": {
      "requireLiteralLeadingDot": false
    }
  }
}
