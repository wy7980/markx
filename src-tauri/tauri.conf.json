{
  "productName": "MarkEdit",
  "version": "${CI_VERSION:-1.0.2}",
  "identifier": "com.markedit.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "MarkEdit",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "label": "main",
        "visible": false,
        "devtools": true
      },
      {
        "label": "splashscreen",
        "url": "splashscreen.html",
        "width": 420,
        "height": 320,
        "decorations": false,
        "center": true,
        "resizable": false,
        "alwaysOnTop": true,
        "transparent": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "installer-hooks.nsh"
      },
      "wix": {
        "fragmentPaths": ["registry.wxs"],
        "componentGroupRefs": ["MarkEditFileAssociations"]
      }
    },
    "macOS": {
      "infoPlist": "Info.plist"
    },
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "name": "Markdown Document",
        "description": "MarkEdit Markdown Document",
        "role": "Editor",
        "mimeType": "text/markdown"
      },
      {
        "ext": ["txt", "text", "log"],
        "name": "Text Document",
        "description": "Plain Text Document",
        "role": "Editor",
        "mimeType": "text/plain"
      },
      {
        "ext": ["js", "jsx", "mjs", "cjs"],
        "name": "JavaScript File",
        "description": "JavaScript Code",
        "role": "Editor",
        "mimeType": "text/javascript"
      },
      {
        "ext": ["ts", "tsx", "mts", "cts"],
        "name": "TypeScript File",
        "description": "TypeScript Code",
        "role": "Editor",
        "mimeType": "application/typescript"
      },
      {
        "ext": ["py"],
        "name": "Python File",
        "description": "Python Script",
        "role": "Editor",
        "mimeType": "text/x-python"
      },
      {
        "ext": ["java"],
        "name": "Java File",
        "description": "Java Source Code",
        "role": "Editor",
        "mimeType": "text/x-java"
      },
      {
        "ext": ["c", "cpp", "cc", "cxx", "h", "hpp"],
        "name": "C/C++ File",
        "description": "C/C++ Source Code",
        "role": "Editor",
        "mimeType": "text/x-c"
      },
      {
        "ext": ["html", "htm"],
        "name": "HTML File",
        "description": "HTML Document",
        "role": "Editor",
        "mimeType": "text/html"
      },
      {
        "ext": ["css"],
        "name": "CSS File",
        "description": "CSS Stylesheet",
        "role": "Editor",
        "mimeType": "text/css"
      },
      {
        "ext": ["json"],
        "name": "JSON File",
        "description": "JSON Data",
        "role": "Editor",
        "mimeType": "application/json"
      },
      {
        "ext": ["xml"],
        "name": "XML File",
        "description": "XML Document",
        "role": "Editor",
        "mimeType": "application/xml"
      },
      {
        "ext": ["yml", "yaml"],
        "name": "YAML File",
        "description": "YAML Configuration",
        "role": "Editor",
        "mimeType": "text/yaml"
      },
      {
        "ext": ["toml"],
        "name": "TOML File",
        "description": "TOML Configuration",
        "role": "Editor",
        "mimeType": "text/toml"
      },
      {
        "ext": ["ini", "cfg", "conf"],
        "name": "Configuration File",
        "description": "INI Configuration",
        "role": "Editor",
        "mimeType": "text/plain"
      },
      {
        "ext": ["sh", "bash"],
        "name": "Shell Script",
        "description": "Shell Script",
        "role": "Editor",
        "mimeType": "text/x-shellscript"
      },
      {
        "ext": ["ps1"],
        "name": "PowerShell Script",
        "description": "PowerShell Script",
        "role": "Editor",
        "mimeType": "text/x-powershell"
      },
      {
        "ext": ["csv"],
        "name": "CSV File",
        "description": "Comma-Separated Values",
        "role": "Editor",
        "mimeType": "text/csv"
      },
      {
        "ext": ["sql"],
        "name": "SQL File",
        "description": "SQL Script",
        "role": "Editor",
        "mimeType": "text/x-sql"
      },
      {
        "ext": ["env"],
        "name": "Environment File",
        "description": "Environment Variables",
        "role": "Editor",
        "mimeType": "text/plain"
      },
      {
        "ext": ["gitignore"],
        "name": "Git Ignore File",
        "description": "Git Ignore Rules",
        "role": "Editor",
        "mimeType": "text/plain"
      }
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "fs": {
      "requireLiteralLeadingDot": false
    }
  }
}
