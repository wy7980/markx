<?xml version="1.0" encoding="utf-8"?>
<!--
  MarkEdit WiX Registry Fragment
  为 MSI 安装包注册文件关联到 Windows 右键"打开方式"菜单。
  Tauri 的默认 WiX 模板不会自动写入 OpenWithProgids，需通过此 fragment 手动完成。
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Fragment>
    <ComponentGroup Id="MarkEditFileAssociations" Directory="TARGETDIR">

      <Component Id="FileAssoc_md" Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">
        <RegistryKey Root="HKCU" Key="Software\Classes\.md\OpenWithProgids" Action="createAndRemoveOnUninstall">
          <RegistryValue Type="string" Name="MarkEdit.md" Value="" />
        </RegistryKey>
      </Component>

      <Component Id="FileAssoc_markdown" Guid="B2C3D4E5-F6A7-8901-BCDE-F01234567891">
        <RegistryKey Root="HKCU" Key="Software\Classes\.markdown\OpenWithProgids" Action="createAndRemoveOnUninstall">
          <RegistryValue Type="string" Name="MarkEdit.md" Value="" />
        </RegistryKey>
      </Component>

      <Component Id="FileAssoc_txt" Guid="C3D4E5F6-A7B8-9012-CDEF-012345678902">
        <RegistryKey Root="HKCU" Key="Software\Classes\.txt\OpenWithProgids" Action="createAndRemoveOnUninstall">
          <RegistryValue Type="string" Name="MarkEdit.md" Value="" />
        </RegistryKey>
      </Component>

      <Component Id="FileAssoc_log" Guid="D4E5F6A7-B8C9-0123-DEF0-123456789013">
